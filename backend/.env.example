# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/dlses

# JWT Secrets (change these in production!)
JWT_SECRET=dlses_jwt_secret_change_me_in_production
JWT_REFRESH_SECRET=dlses_jwt_refresh_secret_change_me_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Google Gemini AI (get your API key from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
